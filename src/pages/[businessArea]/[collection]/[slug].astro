---
import MainLayout from '../../../layouts/MainLayout.astro';
import FormRenderer from '../../../components/forms/FormRenderer.astro';
import { getAllProducts } from '../../../data/products';
import { collections } from '../../../data/collections';
import { getProductOptions } from '../../../data/product-options';
import { productOptionsToFormFields } from '../../../utils/options-to-fields';
import { sitePath } from '../../../utils/paths';
import { getProductPrimaryImage, getProductImages } from '../../../utils/images';
import { formatPrice } from '../../../utils/format';
import type { Product } from '../../../types/product';
import type { Form } from '../../../types/form';

export async function getStaticPaths() {
  const products = getAllProducts();

  return products.map((product) => {
    let collectionSlug = '';

    const matched = collections.find(
      (collection) => collection.id === product.collectionId,
    );

    if (matched) {
      collectionSlug = matched.slug;
    }

    if (!collectionSlug) {
      collectionSlug = product.collectionId.replace(
        `${product.businessArea}-`,
        '',
      );
    }

    return {
      params: {
        businessArea: product.businessArea,
        collection: collectionSlug,
        slug: product.slug,
      },
      props: { product },
    };
  });
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageTone = product.imageTone || 'cream';
const primaryImage = getProductPrimaryImage(product);
const imageStyle = primaryImage
  ? `background-image: url(${primaryImage});`
  : undefined;
const allImages = getProductImages(product);

const statusLabels: Record<string, string> = {
  available: 'Available',
  seasonal: 'Seasonal',
  'out-of-stock': 'Out of Stock',
  preorder: 'Preorder',
};

const statusLabel = statusLabels[product.status] || product.status;

const businessAreaTitle =
  product.businessArea === 'bakery'
    ? 'Bakery'
    : 'Sewing Studio';

const options = getProductOptions(product.id);
const displayPrice = formatPrice(product.price) || product.priceLabel;
const customizationFields = productOptionsToFormFields(options);
const customizationForm: Form | undefined = customizationFields.length > 0
  ? {
      id: `${product.id}-customization`,
      name: product.title,
      title: product.title,
      fields: customizationFields,
    }
  : undefined;

---

<MainLayout
  title={`${product.title} | RIPPLE Bakes & Makes`}
  description={product.shortDescription}
>
  <div class="product-detail">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={sitePath(product.businessArea)}>
          {businessAreaTitle}
        </a>

        <span class="separator" aria-hidden="true">/</span>

        <span class="current" aria-current="page">
          {product.title}
        </span>
      </nav>

      <div class="product-detail__grid">
        <div class="product-detail__media">
          <div
            class:list={[
              'product-detail__image',
              `image-panel--${imageTone}`,
            ]}
            style={imageStyle}
            role="img"
            aria-label={
              primaryImage
                ? product.title
                : `${product.title} visual treatment`
            }
          >
            <span
              class:list={[
                'status-badge',
                `status-badge--${product.status}`,
              ]}
            >
              {statusLabel}
            </span>
          </div>

          {allImages.length > 1 && (
            <div class="product-thumbnails">
              {allImages.map((url) => (
                <div
                  class:list={['product-thumbnail', `image-panel--${imageTone}`]}
                  style={`background-image: url(${url});`}
                  role="img"
                  aria-label={`${product.title} image`}
                ></div>
              ))}
            </div>
          )}
        </div>

        <div class="product-detail__content">
          <span class="eyebrow">{businessAreaTitle}</span>

          <h1 class="display product-detail__title">
            {product.title}
          </h1>

          {product.subtitle && (
            <p class="product-detail__subtitle">
              {product.subtitle}
            </p>
          )}

          {displayPrice && (
            <div class="product-detail__price">
              <span class="price-tag">
                {displayPrice}
              </span>
            </div>
          )}

          <div class="product-detail__description">
            <p class="short-desc">
              {product.shortDescription}
            </p>

            <p class="full-desc">
              {product.description}
            </p>
          </div>

          <div class="product-detail__meta">
            <div class="meta-item">
              <span class="meta-label">
                Availability Status
              </span>

              <span class="meta-value">
                {statusLabel}
              </span>
            </div>
          </div>

          <FormRenderer
            form={customizationForm}
            formId={customizationForm ? undefined : product.formId}
            fallbackTitle={product.title}
            product={{
              collectionId: product.collectionId,
              productId: product.id,
              productTitle: product.title,
            }}
          />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .product-thumbnails {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .product-thumbnail {
    background-position: center;
    background-size: cover;
    border-radius: 0.6rem;
    height: 80px;
    width: 80px;
  }
</style>
