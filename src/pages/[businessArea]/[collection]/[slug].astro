---
import MainLayout from '../../../layouts/MainLayout.astro';
import FormRenderer from '../../../components/forms/FormRenderer.astro';
import ProductGallery from '../../../components/products/ProductGallery.astro';
import { getAllProducts } from '../../../data/products';
import { collections } from '../../../data/collections';
import { getProductOptions } from '../../../data/product-options';
import { productOptionsToFormFields } from '../../../utils/options-to-fields';
import { sitePath } from '../../../utils/paths';
import { getProductPrimaryImage, getProductImages } from '../../../utils/images';
import { formatPrice } from '../../../utils/format';
import type { Product } from '../../../types/product';
import type { Form } from '../../../types/form';

export async function getStaticPaths() {
  const products = getAllProducts();

  return products.map((product) => {
    let collectionSlug = '';

    const matched = collections.find(
      (collection) => collection.id === product.collectionId,
    );

    if (matched) {
      collectionSlug = matched.slug;
    }

    if (!collectionSlug) {
      collectionSlug = product.collectionId.replace(
        `${product.businessArea}-`,
        '',
      );
    }

    return {
      params: {
        businessArea: product.businessArea,
        collection: collectionSlug,
        slug: product.slug,
      },
      props: { product },
    };
  });
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageTone = product.imageTone || 'cream';
const galleryImages = getProductImages(product);
const galleryPrimaryImage = getProductPrimaryImage(product);

const statusLabels: Record<string, string> = {
  available: 'Available',
  seasonal: 'Seasonal',
  'out-of-stock': 'Out of Stock',
  preorder: 'Preorder',
};

const statusLabel = statusLabels[product.status] || product.status;

const businessAreaTitle =
  product.businessArea === 'bakery'
    ? 'Bakery'
    : 'Sewing Studio';

const options = getProductOptions(product.id);
const displayPrice = formatPrice(product.price) || product.priceLabel;
const customizationFields = productOptionsToFormFields(options);
const customizationForm: Form | undefined = customizationFields.length > 0
  ? {
      id: `${product.id}-customization`,
      name: product.title,
      title: product.title,
      fields: customizationFields,
    }
  : undefined;

---

<MainLayout
  title={`${product.title} | RIPPLE Bakes & Makes`}
  description={product.shortDescription}
>
  <div class="product-detail">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={sitePath(product.businessArea)}>
          {businessAreaTitle}
        </a>

        <span class="separator" aria-hidden="true">/</span>

        <span class="current" aria-current="page">
          {product.title}
        </span>
      </nav>

      <div class="product-detail__grid">
        <div class="product-detail__media">
          <ProductGallery
            images={galleryImages}
            primaryImage={galleryPrimaryImage}
            imageTone={imageTone}
            title={product.title}
          >
            <span
              slot="overlay"
              class:list={[
                'status-badge',
                `status-badge--${product.status}`,
              ]}
            >
              {statusLabel}
            </span>
          </ProductGallery>
        </div>

        <div class="product-detail__content">
          <span class="eyebrow">{businessAreaTitle}</span>

          <h1 class="display product-detail__title">
            {product.title}
          </h1>

          {product.subtitle && (
            <p class="product-detail__subtitle">
              {product.subtitle}
            </p>
          )}

          {displayPrice && (
            <div class="product-detail__price">
              <span class="price-tag">
                {displayPrice}
              </span>
            </div>
          )}

          <div class="product-detail__description">
            <p class="short-desc">
              {product.shortDescription}
            </p>

            <p class="full-desc">
              {product.description}
            </p>
          </div>

          <div class="product-detail__meta">
            <div class="meta-item">
              <span class="meta-label">
                Availability Status
              </span>

              <span class="meta-value">
                {statusLabel}
              </span>
            </div>
          </div>

          <FormRenderer
            form={customizationForm}
            formId={customizationForm ? undefined : product.formId}
            fallbackTitle={product.title}
            product={{
              collectionId: product.collectionId,
              productId: product.id,
              productTitle: product.title,
            }}
          />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .product-detail__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  .product-detail__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-detail__title {
    font-size: clamp(1.5rem, 3.5vw, 2.6rem);
    margin: 0;
  }

  .product-detail__subtitle {
    color: var(--muted);
    font-size: 1.05rem;
    margin: 0;
  }

  .product-detail__price {
    margin: 0;
  }

  .price-tag {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--cocoa);
  }

  .product-detail__description {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .product-detail__description .short-desc {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.45;
    margin: 0;
  }

  .product-detail__description .full-desc {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0;
  }

  .product-detail__meta {
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    padding-top: 0.75rem;
  }

  .meta-item {
    display: flex;
    gap: 0.4rem;
  }

  .meta-label {
    color: var(--muted);
  }

  .meta-value {
    font-weight: 600;
  }

  .breadcrumb {
    font-size: 0.82rem;
    margin-bottom: 1.5rem;
    padding-top: 1.5rem;
  }

  .breadcrumb .separator {
    color: var(--line);
    margin: 0 0.35rem;
  }

  .breadcrumb .current {
    color: var(--muted);
  }

  .status-badge {
    border-radius: 99px;
    font-size: 0.62rem;
    font-weight: 600;
    left: 0.75rem;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.55rem;
    position: absolute;
    text-transform: uppercase;
    top: 0.75rem;
    z-index: 2;
  }

  .status-badge--available {
    background: var(--sage);
    color: #fff;
  }

  .status-badge--seasonal {
    background: var(--honey);
    color: var(--cocoa);
  }

  .status-badge--out-of-stock {
    background: #a36e62;
    color: #fff;
  }

  .status-badge--preorder {
    background: var(--cocoa);
    color: #fff;
  }

  @media (min-width: 768px) {
    .product-detail {
      padding-bottom: 5rem;
    }

    .product-detail__grid {
      align-items: start;
      gap: 3rem;
      grid-template-columns: 1fr 1fr;
    }

    .product-detail__content {
      gap: 1.5rem;
      padding-top: 0;
    }

    .breadcrumb {
      margin-bottom: 2.5rem;
      padding-top: 2.5rem;
    }

    .price-tag {
      font-size: 1.8rem;
    }

    .product-detail__description .short-desc {
      font-size: 1.15rem;
    }
  }
</style>
