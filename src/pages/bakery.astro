---
import MainLayout from '../layouts/MainLayout.astro';import SectionTitle from '../components/SectionTitle.astro';import { getBakeryCollections } from '../data/collections';
const bakeryCollections = getBakeryCollections();
---
<MainLayout title="Artisan Bakery | Honeycomb Arts & Bakes" description="Small-batch breads, cookies, cakes, seasonal treats, and custom bakery orders."><section class="page-hero"><div class="container"><span class="eyebrow">The bakery</span><h1 class="display">Baked slowly.<br/><em>Shared gladly.</em></h1><p>Comforting, beautiful bakes for everyday rituals, celebrations, and the people you love to feed.</p></div></section><section class="section"><div class="container"><SectionTitle eyebrow="What’s baking" title="Simple ingredients, <em>thoughtful details.</em>" text="A small, rotating menu of favourites — with room for a very good custom request."/><div class="category-grid">{bakeryCollections.map((collection)=><article><div class={`image-panel image-panel--${collection.imageTone}`}><span class="image-label">{collection.title}</span></div><h2>{collection.title}</h2><p>{collection.shortDescription}</p></article>)}</div></div></section><section class="section section--paper"><div class="container order-callout"><div><span class="eyebrow">Custom orders</span><h2 class="display">Planning a sweet<br/><em>occasion?</em></h2></div><div><p>Tell us what you’re celebrating, who it’s for, and when you need it. We’ll help shape something delicious and distinctly yours.</p><a class="button" href="contact">Ask about an order <span class="arrow">→</span></a></div></div></section></MainLayout>
<style>.category-grid{display:grid;gap:1.2rem;grid-template-columns:repeat(4,1fr)}.category-grid .image-panel{height:230px}.category-grid h2{font-family:'Playfair Display',serif;font-size:1.45rem;font-weight:500;margin:1rem 0 .3rem}.category-grid p{color:var(--muted);font-size:.88rem;margin:0}.order-callout{align-items:center;display:grid;gap:5rem;grid-template-columns:1.1fr .9fr}.order-callout p{color:var(--muted);font-size:1.02rem;margin-top:0}@media(max-width:800px){.category-grid{grid-template-columns:repeat(2,1fr)}.order-callout{gap:2rem;grid-template-columns:1fr}}@media(max-width:460px){.category-grid{grid-template-columns:1fr}}</style>
