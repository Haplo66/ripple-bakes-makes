---
import MainLayout from '../layouts/MainLayout.astro';import SectionTitle from '../components/SectionTitle.astro';import { getSewingCollections } from '../data/collections';
const sewingCollections = getSewingCollections();
---
<MainLayout title="Sewing & Handmade Crafts | Honeycomb Arts & Bakes" description="Custom sewing, repairs, personalized gifts, textile creations, and seasonal handmade crafts."><section class="page-hero"><div class="container"><span class="eyebrow">The handmade studio</span><h1 class="display">Stitched with <em>intention.</em></h1><p>Personalized, practical, and joyfully made pieces for gifting, keeping, and everyday living.</p></div></section><section class="section"><div class="container"><SectionTitle eyebrow="Made by hand" title="Pieces with a story <em>to tell.</em>" text="From small repairs to one-of-a-kind gifts, every project gets the same patient, personal care."/><div class="category-grid">{sewingCollections.map((collection)=><article><div class={`image-panel image-panel--${collection.imageTone}`}><span class="image-label">{collection.title}</span></div><h2>{collection.title}</h2><p>{collection.shortDescription}</p></article>)}</div></div></section><section class="section section--paper"><div class="container order-callout"><div><span class="eyebrow">Your idea, made real</span><h2 class="display">Let’s make it<br/><em>yours.</em></h2></div><div><p>Have a fabric, a feeling, or a particular person in mind? Start a conversation and we’ll explore what’s possible together.</p><a class="button" href="contact">Start a project <span class="arrow">→</span></a></div></div></section></MainLayout>
<style>.category-grid{display:grid;gap:1.2rem;grid-template-columns:repeat(4,1fr)}.category-grid .image-panel{height:230px}.category-grid h2{font-family:'Playfair Display',serif;font-size:1.45rem;font-weight:500;margin:1rem 0 .3rem}.category-grid p{color:var(--muted);font-size:.88rem;margin:0}.order-callout{align-items:center;display:grid;gap:5rem;grid-template-columns:1.1fr .9fr}.order-callout p{color:var(--muted);font-size:1.02rem;margin-top:0}@media(max-width:800px){.category-grid{grid-template-columns:repeat(2,1fr)}.order-callout{gap:2rem;grid-template-columns:1fr}}@media(max-width:460px){.category-grid{grid-template-columns:1fr}}</style>
