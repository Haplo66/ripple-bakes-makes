---
import type { Product } from '../../types/product';
import { getProductPath } from '../../utils/paths';
import { getProductPrimaryImage } from '../../utils/images';
import { formatPrice, formatProductStatus } from '../../utils/format';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageTone = product.imageTone || 'cream';
const primaryImage = getProductPrimaryImage(product);
const cardStyle = primaryImage ? `background-image: url(${primaryImage});` : undefined;
const href = getProductPath(product);

const statusLabel = formatProductStatus(product.status);
const displayPrice = formatPrice(product.price) || product.priceLabel;
---

<article class="product-card">
  <a class="product-card__link" href={href}>
    <div
      class:list={['product-card__image', `image-panel--${imageTone}`]}
      style={cardStyle}
      role="img"
      aria-label={primaryImage ? product.title : `${product.title} image placeholder`}
    >
      <span class:list={['product-card__status', `product-card__status--${product.status}`]}>
        {statusLabel}
      </span>
      {product.featured && <span class="product-card__featured">Featured</span>}
    </div>
    <div class="product-card__content">
      <h3 class="product-card__title">{product.title}</h3>
      {product.subtitle && <p class="product-card__subtitle">{product.subtitle}</p>}
      <p class="product-card__description">{product.shortDescription}</p>
      {displayPrice && <span class="product-card__price">{displayPrice}</span>}
      <span class="product-card__cta">
        View Details <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>

<style>
  .product-card {
    height: 100%;
  }

  .product-card__link {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 1.15rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .product-card__link:hover {
    box-shadow: var(--shadow);
    transform: translateY(-5px);
  }

  .product-card__link:focus-visible {
    box-shadow: 0 0 0 4px rgba(214, 165, 75, 0.45);
    outline: none;
  }

  .product-card__image {
    aspect-ratio: 4 / 3;
    background-position: center;
    background-size: cover;
    overflow: hidden;
    position: relative;
  }

  .product-card__image::after {
    background: linear-gradient(180deg, transparent 40%, rgba(74, 51, 38, 0.3));
    content: '';
    inset: 0;
    position: absolute;
  }

  .product-card__status {
    border-radius: 99px;
    font-size: 0.68rem;
    font-weight: 600;
    left: 1rem;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.65rem;
    position: absolute;
    text-transform: uppercase;
    top: 1rem;
    z-index: 1;
  }

  .product-card__featured {
    background: var(--honey);
    border-radius: 99px;
    color: var(--cocoa);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.55rem;
    position: absolute;
    right: 1rem;
    text-transform: uppercase;
    top: 1rem;
    z-index: 1;
  }

  .product-card__status--available {
    background: var(--sage);
    color: #fff;
  }

  .product-card__status--seasonal {
    background: var(--honey);
    color: var(--cocoa);
  }

  .product-card__status--out-of-stock {
    background: #a36e62;
    color: #fff;
  }

  .product-card__status--preorder {
    background: var(--cocoa);
    color: #fff;
  }

  .product-card__price {
    color: var(--cocoa);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-top: 0.75rem;
  }

  .product-card__content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1.25rem 1.35rem 1.4rem;
  }

  .product-card__title {
    display: -webkit-box;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0;
    overflow: hidden;
  }

  .product-card__subtitle {
    color: var(--sage);
    font-size: 0.85rem;
    font-weight: 500;
    margin: 0.25rem 0 0;
  }

  .product-card__description {
    color: var(--muted);
    display: -webkit-box;
    font-size: 0.88rem;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.5;
    margin: 0.5rem 0 0;
    overflow: hidden;
  }

  .product-card__cta {
    font-size: 0.82rem;
    font-weight: 600;
    margin-top: auto;
    padding-top: 0.75rem;
    transition: color 0.2s ease;
  }

  .product-card__link:hover .product-card__cta span {
    transform: translateX(3px);
  }

  .product-card__cta span {
    color: var(--honey);
    display: inline-block;
    font-size: 1.1rem;
    margin-left: 0.2rem;
    transition: transform 0.2s ease;
  }

  @media (max-width: 400px) {
    .product-card__content {
      padding: 1rem 1rem 1.15rem;
    }

    .product-card__title {
      font-size: 1.25rem;
    }

    .product-card__price {
      font-size: 1rem;
    }
  }
</style>
