---
import type { Form } from '../../types/form';
import FormField from './FormField.astro';

interface Props {
  form: Form;
  product: {
    collectionId: string;
    productId: string;
    productTitle: string;
  };
}

const { form, product } = Astro.props;
---

<form
  class="product-form"
  action="#"
  method="post"
  data-dynamic-form
  data-cart-form
  data-collection-id={product.collectionId}
  data-product-id={product.productId}
  data-product-title={product.productTitle}
>
  <div class="product-form__header">
    <span class="eyebrow">Customize Order</span>
    <h2>{form.title}</h2>
  </div>

  <div class="product-form__fields" data-cart-fields>
    {form.fields.map((field) => <FormField field={field} />)}

    <label class="product-form__quantity">
      Quantity
      <input
        type="number"
        name="quantity"
        min="1"
        step="1"
        value="1"
        required
      />
    </label>
  </div>

  <button class="button button--honey" type="submit">
    Add to cart
    <span class="arrow" aria-hidden="true">→</span>
  </button>

  <p class="product-form__confirmation" data-cart-confirmation hidden>
    Added to cart
  </p>
</form>

<script>
  import { addToCart } from '../../utils/cart';

  const forms = document.querySelectorAll('[data-dynamic-form]');

  forms.forEach((form) => {
    const conditionalFields = form.querySelectorAll('[data-condition-field]');

    const setFieldState = (field, isVisible) => {
      field.hidden = !isVisible;

      field.querySelectorAll('input, select, textarea').forEach((input) => {
        input.disabled = !isVisible;
        input.required =
          isVisible && input.dataset.required === 'true';
      });
    };

    const getFieldValue = (fieldId) => {
      const checked = form.querySelector(
        `[name="${fieldId}"]:checked`,
      );

      if (checked) {
        return checked.value;
      }

      const input = form.querySelector(`[name="${fieldId}"]`);
      return input?.value;
    };

    const updateConditions = () => {
      conditionalFields.forEach((field) => {
        const dependsOn = field.dataset.conditionField;
        const expectedValue = field.dataset.conditionEquals;

        if (!dependsOn) {
          return;
        }

        setFieldState(
          field,
          String(getFieldValue(dependsOn)) === expectedValue,
        );
      });
    };

    form.addEventListener('input', updateConditions);
    form.addEventListener('change', updateConditions);
    updateConditions();
  });

  const cartForms = document.querySelectorAll('[data-cart-form]');

  cartForms.forEach((form) => {
    const confirmation = form.querySelector('[data-cart-confirmation]');

    const getConfiguration = () => {
      const data = new FormData(form);
      const configuration = {};

      data.forEach((value, key) => {
        if (key === 'quantity' || key === 'notes') {
          return;
        }

        const stringValue = String(value);
        const currentValue = configuration[key];

        if (Array.isArray(currentValue)) {
          currentValue.push(stringValue);
          return;
        }

        if (typeof currentValue === 'string') {
          configuration[key] = [currentValue, stringValue];
          return;
        }

        configuration[key] = stringValue;
      });

      return configuration;
    };

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      const formData = new FormData(form);
      const quantity = Number(formData.get('quantity') || 1);
      const notesValue = formData.get('notes');

      addToCart({
        collectionId: form.dataset.collectionId || '',
        productId: form.dataset.productId || '',
        productTitle: form.dataset.productTitle || '',
        configuration: getConfiguration(),
        quantity,
        notes: notesValue ? String(notesValue) : undefined,
      });

      if (confirmation) {
        confirmation.hidden = false;
      }
    });
  });
</script>

<style>
  .product-form {
    background: #f6eddf;
    border-radius: 1.1rem;
    margin-top: 1.75rem;
    padding: 1.5rem;
  }

  .product-form__header {
    margin-bottom: 1.15rem;
  }

  .product-form__header h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: -.035em;
    line-height: 1.1;
    margin: .4rem 0 0;
  }

  .product-form__fields {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr 1fr;
    margin-bottom: 1.2rem;
  }

  .product-form__fields :global(.form-field:has(textarea)),
  .product-form__fields :global(.form-field:has(fieldset)) {
    grid-column: span 2;
  }

  .product-form__quantity {
    color: var(--cocoa);
    display: flex;
    flex-direction: column;
    font-size: .78rem;
    font-weight: 600;
    gap: .4rem;
  }

  .product-form__quantity input {
    background: #fffdfa;
    border: 1px solid var(--line);
    border-radius: .55rem;
    color: var(--cocoa);
    font-size: .92rem;
    outline-color: var(--honey);
    padding: .72rem .8rem;
  }

  .product-form__confirmation {
    color: var(--sage);
    font-size: .85rem;
    font-weight: 600;
    margin: .85rem 0 0;
  }

  @media (max-width: 620px) {
    .product-form__fields {
      grid-template-columns: 1fr;
    }

    .product-form__fields :global(.form-field:has(textarea)),
    .product-form__fields :global(.form-field:has(fieldset)) {
      grid-column: auto;
    }
  }
</style>
