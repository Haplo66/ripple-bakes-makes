---
import SectionTitle from './SectionTitle.astro';
import type { Collection } from '../types/collection';
interface Props { collection: Collection }
const { collection } = Astro.props;
const heroStyle = collection.heroImage ? `background-image: url(${collection.heroImage});` : undefined;
---
<section class={`collection-hero image-panel--${collection.imageTone}`} style={heroStyle}><div class="container"><span class="eyebrow">{collection.category} collection</span><h1 class="display">{collection.title}</h1><p>{collection.subtitle}</p></div></section>
<section class="section"><div class="container intro"><span class="eyebrow">About this collection</span><p>{collection.description}</p></div></section>
<section class="section section--paper"><div class="container"><SectionTitle eyebrow="Gallery" title={`A closer look at <em>${collection.title.toLowerCase()}.</em>`}/><div class="collection-gallery">{collection.galleryImages.map((image)=><figure><div class:list={['collection-gallery__image',`image-panel--${image.tone}`]} style={image.src ? `background-image: url(${image.src});` : undefined} role="img" aria-label={image.alt}></div><figcaption>{image.caption}</figcaption></figure>)}</div></div></section>
<section class="section"><div class="container"><SectionTitle eyebrow="Popular ideas" title="A few ways to make it <em>yours.</em>"/><ul class="ideas">{collection.popularIdeas.map((idea,index)=><li><span>0{index + 1}</span>{idea}</li>)}</ul></div></section>
<section class="section section--paper"><div class="container customization"><div><span class="eyebrow">Customization</span><h2 class="display">Made with your<br/><em>details</em> in mind.</h2></div><p>{collection.customizationNote}</p></div></section>
<style>.collection-hero{background:linear-gradient(135deg,#f2e3c9,#b98969);min-height:430px;padding:8rem 0 5rem;position:relative}.collection-hero:before{background:linear-gradient(90deg,rgba(74,51,38,.26),transparent);content:'';inset:0;position:absolute}.collection-hero .container{position:relative}.collection-hero .eyebrow{color:#fff7ea}.collection-hero .display{color:#fff;max-width:700px}.collection-hero p{color:#fff7ea;font-size:1.1rem;max-width:500px}.intro{max-width:760px}.intro>p{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.3rem);line-height:1.35;margin:.8rem 0 0}.collection-gallery{display:grid;gap:1rem;grid-template-columns:repeat(3,1fr)}.collection-gallery figure{margin:0}.collection-gallery__image{background-size:cover;height:300px}.collection-gallery figcaption{color:var(--muted);font-size:.82rem;margin-top:.6rem}.ideas{display:grid;gap:1rem;grid-template-columns:repeat(3,1fr);list-style:none;margin:0;padding:0}.ideas li{border-top:1px solid var(--line);font-family:'Playfair Display',serif;font-size:1.35rem;padding-top:.8rem}.ideas span{color:var(--sage);display:block;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;letter-spacing:.1em;margin-bottom:.5rem}.customization{align-items:center;display:grid;gap:4rem;grid-template-columns:1fr 1fr}.customization p{color:var(--muted);font-size:1.05rem}@media(max-width:720px){.collection-hero{min-height:370px;padding-top:6rem}.collection-gallery,.ideas{grid-template-columns:1fr}.collection-gallery__image{height:250px}.customization{gap:1.5rem;grid-template-columns:1fr}}</style>
