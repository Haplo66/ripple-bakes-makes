---
import Logo from './Logo.astro';
---
<footer class="site-footer"><div class="container footer-grid"><div><Logo variant="footer"/><p>Handcrafted treats and handmade creations, made with care.</p></div><div><h2>Explore</h2><a href="bakery">Artisan bakery</a><a href="sewing">Sewing &amp; crafts</a><a href="gallery">Gallery</a></div><div><h2>Say hello</h2><a href="contact">Start an order</a><a href="about">Our story</a><p class="small">Serving our local community<br/>with thoughtful, small-batch work.</p></div></div><div class="container footer-bottom"><span>© {new Date().getFullYear()} RIPPLE Bakes &amp; Makes</span><span>Made with care, always.</span></div></footer>
<style>.site-footer{background:var(--cocoa);color:#fff7ea;padding:4.5rem 0 1.35rem}.footer-grid{display:grid;gap:2.5rem;grid-template-columns:2fr 1fr 1fr}.site-footer .logo{color:#fff}.site-footer .logo small{color:var(--gold)}.site-footer p{color:#dfcdbb;max-width:285px}.site-footer h2{color:var(--gold);font-size:.72rem;letter-spacing:.14em;margin:0 0 .9rem;text-transform:uppercase}.site-footer a{color:#fff7ea;display:block;font-size:.9rem;margin:.55rem 0}.site-footer .small{font-size:.8rem;line-height:1.5}.footer-bottom{border-top:1px solid rgba(255,255,255,.16);color:#dfcdbb;display:flex;font-size:.75rem;justify-content:space-between;margin-top:3.4rem;padding-top:1.2rem}@media(max-width:650px){.footer-grid{grid-template-columns:1fr 1fr}.footer-grid>div:first-child{grid-column:span 2}.footer-bottom{gap:.5rem;flex-direction:column}}</style>
