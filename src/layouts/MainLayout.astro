---
import { sitePath } from '../utils/paths';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const {title='RIPPLE Bakes & Makes',description='Handcrafted treats and handmade creations, made with care.'}=Astro.props;
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><base href={`${import.meta.env.BASE_URL}/`}/><meta name="description" content={description}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/><meta name="theme-color" content="#FFF9F1"/><link rel="icon" type="image/png" href={sitePath('ripple-symbol.png')} />
<link rel="apple-touch-icon" href={sitePath('ripple-symbol.png')} /><title>{title}</title></head><body><Header/><main><slot/></main><Footer/></body></html>
